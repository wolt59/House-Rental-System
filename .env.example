# Database URL for MySQL
# Replace YOUR_PASSWORD with your MySQL root password
SQLALCHEMY_DATABASE_URI=mysql+pymysql://root:YOUR_PASSWORD@127.0.0.1:3306/house_rental

# Secret key for JWT token (generate a random string for production)
SECRET_KEY=your-secret-key-change-me-in-production

# Token expiration time in minutes (7 days = 10080 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS allowed origins
BACKEND_CORS_ORIGINS=["*"]

# Backend server port (default: 8000)
BACKEND_PORT=8000

# Frontend configuration - Backend API address
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_UPLOADS_BASE_URL=http://127.0.0.1:8000

# Frontend server configuration
FRONTEND_PORT=3000
# Set to '0.0.0.0' to allow access from other devices, 'localhost' for local only
FRONTEND_HOST=localhost
